<?xml version="1.0"?>
<robot name="simple_quadrotor">

  <!-- ===================== -->
  <!-- Base (body)           -->
  <!-- ===================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0023" ixy="0" ixz="0" iyy="0.0023" iyz="0" izz="0.004"/>
    </inertial>

    <!-- Simple body visual -->
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.05"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>

    <!-- Simple collision -->
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- ===================== -->
  <!-- Rotor links           -->
  <!-- ===================== -->

  <!-- Front (x+) -->
  <link name="rotor1">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.01"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Left (y+) -->
  <link name="rotor2">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Back (x−) -->
  <link name="rotor3">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.01"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- Right (y−) -->
  <link name="rotor4">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.01"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- ===================== -->
  <!-- Fixed joints          -->
  <!-- ===================== -->

  <joint name="joint_rotor1" type="fixed">
    <parent link="base_link"/>
    <child link="rotor1"/>
    <origin xyz="0.15 0 0"/>
  </joint>

  <joint name="joint_rotor2" type="fixed">
    <parent link="base_link"/>
    <child link="rotor2"/>
    <origin xyz="0 0.15 0"/>
  </joint>

  <joint name="joint_rotor3" type="fixed">
    <parent link="base_link"/>
    <child link="rotor3"/>
    <origin xyz="-0.15 0 0"/>
  </joint>

  <joint name="joint_rotor4" type="fixed">
    <parent link="base_link"/>
    <child link="rotor4"/>
    <origin xyz="0 -0.15 0"/>
  </joint>

</robot>